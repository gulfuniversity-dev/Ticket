# ===== Database (Supabase Postgres) =====
# Use the Session pooler (port 5432) connection string from Supabase > Project Settings > Database.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres

# ===== Auth =====
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ===== App =====
NEXT_PUBLIC_APP_NAME=Gulf University Graduation 2026
NEXT_PUBLIC_CEREMONY_TITLE=Gulf University Graduation Ceremony — Spring 2025/2026

# ===== Email delivery (Office 365 SMTP) =====
# A university mailbox that will send the tickets. With MFA, generate an
# "app password" for it. Note: the tenant must allow SMTP AUTH for this mailbox.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=graduation@gulfuniversity.edu.bh
SMTP_PASS=your-app-password
MAIL_FROM=graduation@gulfuniversity.edu.bh
MAIL_FROM_NAME=Gulf University Graduation
# Student email = <StudentID>@<this domain>
STUDENT_EMAIL_DOMAIN=gulfuniversity.edu.bh
# Shared secret so scripts/send-tickets.mjs can call the email endpoint.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
EMAIL_BULK_SECRET=change-me-to-a-long-random-secret
# Base URL the bulk script posts to (the running app).
APP_URL=http://localhost:3000

# ===== Default seeded accounts =====
ADMIN_EMAIL=admin@gulfuniversity.edu.bh
ADMIN_PASSWORD=Admin@2026
GATE_EMAIL=gate@gulfuniversity.edu.bh
GATE_PASSWORD=Gate@2026
