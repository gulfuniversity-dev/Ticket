# ===== Database (Supabase Postgres) =====
# Use the Session pooler (port 5432) connection string from Supabase > Project Settings > Database.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres

# ===== Auth =====
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-secret

# ===== App =====
NEXT_PUBLIC_APP_NAME=Gulf University Graduation 2026
NEXT_PUBLIC_CEREMONY_TITLE=Gulf University Graduation Ceremony — Spring 2025/2026

# ===== Default seeded accounts =====
ADMIN_EMAIL=admin@gulfuniversity.edu.bh
ADMIN_PASSWORD=Admin@2026
GATE_EMAIL=gate@gulfuniversity.edu.bh
GATE_PASSWORD=Gate@2026
